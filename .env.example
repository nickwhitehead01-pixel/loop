# ── Database ──────────────────────────────────────────────────────
# For local development, PostgreSQL runs in Docker via docker-compose
# For production, update to your managed database URL
DATABASE_URL=postgresql+asyncpg://gemma_user:gemma_password@localhost:5432/gemma_education

# ── Ollama ────────────────────────────────────────────────────────────
# DEVELOPMENT SETUP (recommended):
#   1. Run Ollama on your host machine: `ollama serve`
#   2. Use OLLAMA_BASE_URL=http://localhost:11434 (backend connects to host Ollama)
#   3. Do NOT use the ollama service in docker-compose.yml during dev
#      (comment it out in docker-compose.yml to save resources)
#
# DOCKER DEPLOYMENT:
#   Use docker-compose.yml as-is — Ollama runs inside the container
#   OLLAMA_BASE_URL stays http://ollama:11434 (internal container network)
#
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PUPIL=gemma4:e2b
OLLAMA_MODEL_TEACHER=gemma4:e2b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── App ───────────────────────────────────────────────────────────
DEBUG=false
UPLOAD_DIR=/app/uploads
MEMORY_WINDOW=20

# ── Frontend (Next.js public env vars) ────────────────────────────
# Local development (running frontend inside Docker or locally against local backend)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Partner development via ngrok (replace with URL printed by `ngrok http 8000`)
# NEXT_PUBLIC_API_URL=https://abc123.ngrok-free.app
# NEXT_PUBLIC_WS_URL=wss://abc123.ngrok-free.app
